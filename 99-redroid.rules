# /etc/udev/rules.d/99-redroid.rules
# Allow non-root access to Android IPC devices for redroid containers.

# ashmem device
KERNEL=="ashmem", NAME="%k", MODE="0666"

# binder devices created by binderfs
SUBSYSTEM=="misc", KERNEL=="binder", MODE="0666"
SUBSYSTEM=="misc", KERNEL=="hwbinder", MODE="0666"
SUBSYSTEM=="misc", KERNEL=="vndbinder", MODE="0666"
